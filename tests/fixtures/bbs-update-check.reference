#!/usr/bin/env bash
# bbs-update-check — periodic version check.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>       — marker found from recent upgrade
#   UPGRADE_AVAILABLE <old> <new>   — remote VERSION differs from local
#   (nothing)                       — up to date, snoozed, disabled, or skipped
#
# Env overrides (for testing):
#   BABYSIT_DIR         — override auto-detected babysit root
#   BABYSIT_REMOTE_URL  — override remote VERSION URL
#   BABYSIT_STATE_DIR   — override ~/.babysit state directory
set -euo pipefail

BABYSIT_DIR="${BABYSIT_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${BABYSIT_STATE_DIR:-$HOME/.babysit}"
CACHE_FILE="$STATE_DIR/last-update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
VERSION_FILE="$BABYSIT_DIR/VERSION"
REMOTE_URL="${BABYSIT_REMOTE_URL:-https://raw.githubusercontent.com/reallongnguyen/babysit/main/VERSION}"

# ─── Force flag (busts cache + snooze) ───────────────────────
if [ "${1:-}" = "--force" ]; then
  rm -f "$CACHE_FILE" "$SNOOZE_FILE"
fi

# ─── Step 0: Check if updates are disabled ────────────────────
_UC=$("$BABYSIT_DIR/bin/bbs-config" get update_check 2>/dev/null || true)
[ "$_UC" = "false" ] && exit 0

# ─── Snooze helper ───────────────────────────────────────────
# Snooze file format: <version> <level> <epoch>
# Level durations: 1=24h, 2=48h, 3+=7d
# New remote version resets snooze.
check_snooze() {
  local remote_ver="$1"
  [ -f "$SNOOZE_FILE" ] || return 1

  local sv sl se
  sv="$(awk 'NR==1 {print $1; exit}' "$SNOOZE_FILE" 2>/dev/null || true)"
  sl="$(awk 'NR==1 {print $2; exit}' "$SNOOZE_FILE" 2>/dev/null || true)"
  se="$(awk 'NR==1 {print $3; exit}' "$SNOOZE_FILE" 2>/dev/null || true)"

  [ -z "$sv" ] || [ -z "$sl" ] || [ -z "$se" ] && return 1
  case "$sl" in *[!0-9]*) return 1 ;; esac
  case "$se" in *[!0-9]*) return 1 ;; esac
  [ "$sv" != "$remote_ver" ] && return 1

  local duration
  case "$sl" in
    1) duration=86400 ;;
    2) duration=172800 ;;
    *) duration=604800 ;;
  esac

  local now expires
  now="$(date +%s)"
  expires=$(( se + duration ))
  [ "$now" -lt "$expires" ] && return 0
  return 1
}

# ─── Step 1: Read local version ──────────────────────────────
LOCAL=""
[ -f "$VERSION_FILE" ] && LOCAL="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')"
[ -z "$LOCAL" ] && exit 0

# ─── Step 2: Check "just upgraded" marker ────────────────────
if [ -f "$MARKER_FILE" ]; then
  OLD="$(cat "$MARKER_FILE" 2>/dev/null | tr -d '[:space:]')"
  rm -f "$MARKER_FILE" "$SNOOZE_FILE"
  [ -n "$OLD" ] && echo "JUST_UPGRADED $OLD $LOCAL"
fi

# ─── Step 3: Check cache freshness ───────────────────────────
# UP_TO_DATE: 60 min TTL; UPGRADE_AVAILABLE: 720 min TTL.
if [ -f "$CACHE_FILE" ]; then
  CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
  case "$CACHED" in
    UP_TO_DATE*)        CACHE_TTL=60 ;;
    UPGRADE_AVAILABLE*) CACHE_TTL=720 ;;
    CHECK_FAILED*)      CACHE_TTL=15 ;;
    *)                  CACHE_TTL=0 ;;
  esac

  STALE=$(find "$CACHE_FILE" -mmin +$CACHE_TTL 2>/dev/null || true)
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE*)
        CACHED_VER="$(echo "$CACHED" | awk '{print $2}')"
        [ "$CACHED_VER" = "$LOCAL" ] && exit 0
        ;;
      UPGRADE_AVAILABLE*)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_OLD" = "$LOCAL" ]; then
          CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
          check_snooze "$CACHED_NEW" && exit 0
          echo "$CACHED"
          exit 0
        fi
        ;;
    esac
  fi
fi

# ─── Step 4: Slow path — fetch remote version ────────────────
mkdir -p "$STATE_DIR"

if ! REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null)"; then
  # Network failure: record with short TTL so we retry soon (15 min) but don't hammer.
  echo "CHECK_FAILED $LOCAL" > "$CACHE_FILE"
  exit 0
fi
REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"

# Reject non-version responses (HTML error pages, empty, etc.)
if ! echo "$REMOTE" | grep -qE '^[0-9]+\.[0-9.]+$'; then
  echo "CHECK_FAILED $LOCAL" > "$CACHE_FILE"
  exit 0
fi

if [ "$LOCAL" = "$REMOTE" ]; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE"
check_snooze "$REMOTE" && exit 0
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
