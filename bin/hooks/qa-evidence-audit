#!/usr/bin/env bash
# PostToolUse(Bash) qa-evidence auditor.
#
# Fires after a `bbs-ticket set-verdict --skill qa` writes verdicts/qa.md — the
# one moment the persisted qa verdict is guaranteed to exist (the qa Skill hook
# can't check it: set-verdict runs as a separate Bash call *after* the skill
# returns). Re-checks the verdict against the coverage rubric it claims: a
# PASS/FIXED must show freshness=A, no C/D dimension, and evidence naming a real
# end-to-end run; a non-PASS status must name a blocker.
#
# Audit-only — PostToolUse cannot block the write that already happened. It
# logs to skill-usage.jsonl (babysit's feedback channel) and warns via
# systemMessage so the model fixes the verdict before the push/PR gate denies
# it. The hard stop lives in pre-tool-gate, which reads the same qa-evidence.
#
# Input:  hook JSON on stdin (.tool_input.command).
# Output: optional systemMessage JSON; always exit 0.
set -uo pipefail

command -v jq >/dev/null 2>&1 || exit 0

INPUT="$(cat)"
CMD="$(printf '%s' "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null)"
[ -n "$CMD" ] || exit 0

# Only audit the qa verdict write — fast no-op on every other Bash command.
printf '%s' "$CMD" | grep -qE 'set-verdict' || exit 0
printf '%s' "$CMD" | grep -qE -- '--skill[[:space:]=]+qa([[:space:]]|$)' || exit 0

# Resolve bbs-ticket the way the preamble / other hooks do.
# Sets BBS_ARGV to the argv that serves "$1"; returns 1 if nothing does. The
# multicall fallback (`bbs <sub>`) is two words, hence an array. Audit-only
# hook: an unresolvable bin exits 0 quietly — never block on it.
_resolve() { # $1=bbs-<sub>
  local name="$1" sub="${1#bbs-}" c
  BBS_ARGV=()
  for c in "$HOME/.claude/$name" "$HOME/.claude/skills/babysit/bin/$name"; do
    if [ -x "$c" ]; then BBS_ARGV=("$c"); return 0; fi
  done
  if command -v "$name" >/dev/null 2>&1; then BBS_ARGV=("$name"); return 0; fi
  # bin/bbs-<sub> dangles (symlink → the gitignored bin/bbs, not built here).
  # Probe the multicall binary for <sub> before trusting it: `bbs <sub>` on a
  # binary without that subcommand exits 1 silently (root.go SilenceErrors).
  # `bbs help <sub>` is not a usable probe — cobra exits 0 for unknown topics.
  for c in "$HOME/.claude/bbs" "$HOME/.claude/skills/babysit/bin/bbs" bbs; do
    if command -v "$c" >/dev/null 2>&1 && "$c" "$sub" --help >/dev/null 2>&1; then
      BBS_ARGV=("$c" "$sub"); return 0
    fi
  done
  return 1
}
_resolve bbs-ticket || exit 0
TB=("${BBS_ARGV[@]}")
"${TB[@]}" resolve >/dev/null 2>&1 || exit 0
STATE="$("${TB[@]}" qa-evidence 2>/dev/null || echo none)"

TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
LOG="$HOME/.babysit/analytics/skill-usage.jsonl"
mkdir -p "$(dirname "$LOG")" 2>/dev/null || true
printf '{"ts":"%s","event":"qa-evidence-audit","state":"%s"}\n' "$TS" "$STATE" >> "$LOG" 2>/dev/null || true

case "$STATE" in
  ok|none) : ;;
  contradiction:*)
    printf '{"systemMessage":"qa-evidence: qa verdict claims PASS but its own rubric disproves it (%s) — a PASS requires freshness=A and no C/D dimension. Re-run the e2e pass on the final code, or downgrade to FAIL / DONE_WITH_CONCERNS with the reason."}\n' "${STATE#contradiction:}"
    ;;
  thin:*)
    printf '{"systemMessage":"qa-evidence: qa PASS verdict has %s — the EVIDENCE line must name a real end-to-end run (browser or API journey + observed result + screenshot path under evidence/qa/), not code reads or a bare status. Add it or downgrade the verdict."}\n' "${STATE#thin:}"
    ;;
  unexplained)
    printf '{"systemMessage":"qa-evidence: qa verdict is not a clean PASS but names no blocker. If the app could not be tested or a case was skipped, the verdict must say why — set DONE_WITH_CONCERNS (or BLOCKED) with the named blocker in SUMMARY/EVIDENCE."}\n'
    ;;
esac
exit 0
