#!/usr/bin/env bash
# bbs-upgrade — pull latest babysit, re-run setup, write just-upgraded marker.
#
# Respects bbs-config auto_upgrade=false by default; run this script explicitly
# to upgrade. Use `--snooze <level>` to silence prompts for a version without
# upgrading: 1=24h, 2=48h, 3=7d.
set -euo pipefail

BABYSIT_DIR="${BABYSIT_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${BABYSIT_STATE_DIR:-$HOME/.babysit}"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
CACHE_FILE="$STATE_DIR/last-update-check"
VERSION_FILE="$BABYSIT_DIR/VERSION"

mkdir -p "$STATE_DIR"

# ─── Snooze mode ─────────────────────────────────────────────
if [ "${1:-}" = "--snooze" ]; then
  LEVEL="${2:-1}"
  case "$LEVEL" in 1|2|3) ;; *) echo "snooze level must be 1, 2, or 3" >&2; exit 1 ;; esac
  # Pull the pending UPGRADE_AVAILABLE <local> <remote> from cache
  REMOTE=""
  if [ -f "$CACHE_FILE" ]; then
    REMOTE="$(awk '/^UPGRADE_AVAILABLE/{print $3}' "$CACHE_FILE" 2>/dev/null || true)"
  fi
  [ -z "$REMOTE" ] && { echo "no pending upgrade to snooze" >&2; exit 1; }
  echo "$REMOTE $LEVEL $(date +%s)" > "$SNOOZE_FILE"
  echo "Snoozed upgrade to $REMOTE (level $LEVEL)."
  exit 0
fi

# ─── Capture current version before pulling ──────────────────
OLD_VERSION=""
[ -f "$VERSION_FILE" ] && OLD_VERSION="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')"

# ─── Pull latest ─────────────────────────────────────────────
if ! command -v git >/dev/null 2>&1; then
  echo "git is required for bbs-upgrade" >&2
  exit 1
fi

cd "$BABYSIT_DIR"
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "babysit was not installed via git clone — cannot auto-upgrade" >&2
  echo "Reinstall manually: https://github.com/reallongnguyen/babysit" >&2
  exit 1
fi

echo "→ Pulling latest babysit..."
git pull --ff-only || {
  echo "git pull failed — resolve conflicts then re-run bbs-upgrade" >&2
  exit 1
}

# ─── Re-link skills ──────────────────────────────────────────
echo "→ Relinking skills..."
"$BABYSIT_DIR/bin/setup-skills" >/dev/null

# ─── Mark upgrade + clear caches ─────────────────────────────
NEW_VERSION=""
[ -f "$VERSION_FILE" ] && NEW_VERSION="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')"

if [ -n "$OLD_VERSION" ] && [ "$OLD_VERSION" != "$NEW_VERSION" ]; then
  echo "$OLD_VERSION" > "$MARKER_FILE"
fi
rm -f "$CACHE_FILE" "$SNOOZE_FILE"

echo "✓ babysit upgraded${OLD_VERSION:+: $OLD_VERSION → $NEW_VERSION}"
