#!/usr/bin/env bash
# bbs-secrets — project-local env-var auto-loader for babysit skills.
#
# Subcommands:
#   load
#       Walk up from $PWD to find the nearest dir containing .babysit/ and
#       load <repo>/.babysit/.env.
#       Emits `export KEY='ESCAPED_VAL'` lines for keys NOT already in shell env.
#       Consumer: `eval "$(bbs-secrets load)"`.
#
#       Precedence (highest wins): shell-exported value > repo file.
#
#   seed --repo-root <path> <var>...
#       Idempotently create <path>/.babysit/.env with `# <var>=` commented placeholders.
#       Calls ensure-gitignore internally first (defense-in-depth: file is
#       gitignored before any value can land in it). Prints `created: <path>`
#       or `exists: <path>`.
#
#   ensure-gitignore --repo-root <path>
#       Idempotently append `.babysit/.env` to <path>/.gitignore. Prints
#       `added` or `present`.
#
# Caller-discipline rule for wizards: always run ensure-gitignore BEFORE seed,
# so the file's path is gitignored before any value lands in it. seed enforces
# this internally as defense-in-depth.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || python3 -c "import os; print(os.path.realpath('$0'))")")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/load-env-file.sh
. "$PROJECT_ROOT/lib/load-env-file.sh"

# ─── helpers ─────────────────────────────────────────────────────────

# Walk up from $1 (default $PWD) looking for a dir containing .babysit/.
# Echo its absolute path (via `pwd -P`); empty if none found.
_find_repo_root() {
  local d="${1:-$PWD}"
  d="$(cd "$d" 2>/dev/null && pwd -P)" || return 0
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    if [ -d "$d/.babysit" ]; then
      printf '%s\n' "$d"
      return 0
    fi
    d="$(dirname "$d")"
  done
}

# ─── load ────────────────────────────────────────────────────────────

cmd_load() {
  local repo_root repo_env=""

  repo_root="$(_find_repo_root)"
  [ -n "$repo_root" ] && repo_env="$repo_root/.babysit/.env"

  # Nothing to load → silent no-op.
  [ -z "$repo_env" ] && return 0

  # Snapshot env BEFORE mutation so we know which keys to emit afterwards.
  # NOTE: not local — the EXIT trap needs it visible after cmd_load returns.
  _snapshot="$(mktemp)"
  trap 'rm -f "${_snapshot:-}"' EXIT
  compgen -v | sort -u > "$_snapshot"

  # Existing shell exports win via the printenv check in _load_env_file.
  [ -n "$repo_env" ] && _load_env_file "$repo_env"

  # Emit `export KEY='val'` for every newly-set key. BASH_REMATCH is set as
  # a side-effect of regex matches inside _load_env_file; suppress it (and
  # any other reserved-name bash internals) so the eval output stays clean.
  local key val val_esc
  while IFS= read -r key; do
    [ -n "$key" ] || continue
    case "$key" in
      BASH_REMATCH|BASH_LINENO|BASH_SOURCE|FUNCNAME|PIPESTATUS|_) continue ;;
    esac
    if ! grep -qxF "$key" "$_snapshot"; then
      val="$(printenv "$key" || true)"
      # Explicit single-quote escape: close-quote, backslash-escaped quote, reopen.
      # POSIX-portable, no printf %q dependency, safe for $/`/"/whitespace.
      val_esc="${val//\'/\'\\\'\'}"
      printf "export %s='%s'\n" "$key" "$val_esc"
    fi
  done < <(compgen -v | sort -u)
}

# ─── seed ────────────────────────────────────────────────────────────

cmd_seed() {
  local repo_root=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo-root) repo_root="$2"; shift 2 ;;
      --) shift; break ;;
      -*) echo "bbs-secrets seed: unknown flag: $1" >&2; exit 2 ;;
      *) break ;;
    esac
  done
  [ -n "$repo_root" ] || { echo "bbs-secrets seed: --repo-root is required" >&2; exit 2; }
  [ -d "$repo_root" ] || { echo "bbs-secrets seed: not a directory: $repo_root" >&2; exit 2; }

  # Defense-in-depth: gitignore FIRST, even if caller forgot.
  cmd_ensure_gitignore --repo-root "$repo_root" >/dev/null

  mkdir -p "$repo_root/.babysit"
  local target="$repo_root/.babysit/.env"

  if [ -f "$target" ]; then
    printf 'exists: %s\n' "$target"
    return 0
  fi

  {
    printf '# Project-local env vars for babysit qa credential resolution.\n'
    printf '# Uncomment a line and fill in the value to populate the matching\n'
    printf '# %s shell variable for /bbs:qa.\n' '$NAME'
    printf '# This file is gitignored — never commit values.\n'
    printf '\n'
    local v
    for v in "$@"; do
      [ -n "$v" ] && printf '# %s=\n' "$v"
    done
  } > "$target"

  printf 'created: %s\n' "$target"
}

# ─── ensure-gitignore ────────────────────────────────────────────────

cmd_ensure_gitignore() {
  local repo_root=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo-root) repo_root="$2"; shift 2 ;;
      --) shift; break ;;
      -*) echo "bbs-secrets ensure-gitignore: unknown flag: $1" >&2; exit 2 ;;
      *) break ;;
    esac
  done
  [ -n "$repo_root" ] || { echo "bbs-secrets ensure-gitignore: --repo-root is required" >&2; exit 2; }
  [ -d "$repo_root" ] || { echo "bbs-secrets ensure-gitignore: not a directory: $repo_root" >&2; exit 2; }

  local gi="$repo_root/.gitignore"
  touch "$gi"
  if grep -qxF '.babysit/.env' "$gi" 2>/dev/null; then
    printf 'present\n'
  else
    printf '.babysit/.env\n' >> "$gi"
    printf 'added\n'
  fi
}

# ─── dispatch ────────────────────────────────────────────────────────

SUB="${1:-help}"
[ $# -gt 0 ] && shift || true

case "$SUB" in
  load)             cmd_load "$@" ;;
  seed)             cmd_seed "$@" ;;
  ensure-gitignore) cmd_ensure_gitignore "$@" ;;
  help|-h|--help|"")
    sed -n '2,/^set -euo pipefail/p' "$0" | sed 's|^# \?||;s|^set.*||' | sed '/^$/N;/^\n$/D'
    ;;
  *)
    echo "bbs-secrets: unknown subcommand: $SUB" >&2
    exit 2
    ;;
esac
