__pycache__
.pytest_cache/

# Repo-scoped gh CLI config (holds OAuth token — do NOT commit)
.gh-config/

# direnv local env (already applied via .envrc; optional personal overrides)
.envrc.local

# Ephemeral review reports written by /bbs:review
.babysit/review-reports/

# Skill-creator eval harness outputs (per-skill workspace dirs)
.claude/skills/.evals/

# Per-project qa-config dev overrides — real secrets allowed here only.
# The committed .babysit/qa.yaml uses env-var indirection
# (credentials.{username_env,password_env}); this file is the gitignored
# escape hatch for inline values during local dev.
.babysit/qa.local.yaml

# Go CLI build output (compiled by bin/setup-skills; bin/bbs-config and
# bin/bbs-qa-config symlink to it)
/bin/bbs

# Dashboard build outputs (generated by `bbs-dashboard build` / `bbs-dashboard`)
web/node_modules/
web/dist/
web/data.js
web/public/data.js
web/*.tsbuildinfo

# browse skill — `bun init` scaffold leftovers (not the real source under src/)
.claude/skills/browse/.cursor/
.claude/skills/browse/.gitignore
.claude/skills/browse/CLAUDE.md
.claude/skills/browse/README.md
.claude/skills/browse/bun.lock
.claude/skills/browse/index.ts
.claude/skills/browse/package.json
.claude/skills/browse/tsconfig.json

# Browse skill runtime IPC (sidebar-inbox observation queue)
.context/
repositories/
workspace/
.babysit/
.repos/
dev/
